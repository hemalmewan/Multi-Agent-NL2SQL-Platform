##################################################################
## .env.sample — Environment Variable Template
##
## This is a safe-to-commit template showing all required
## environment variables with empty values.
##
## USAGE:
##   1. Copy this file:  cp .env.sample .env
##   2. Fill in each variable in .env with your actual credentials
##   3. Never commit the populated .env file
##
## Variables:
##   OPENROUTER_API_KEY   — API key from openrouter.ai
##   OEPNAI_API_KEY       — API key from platform.openai.com
##   SUPABASE_URL         — Project URL from Supabase dashboard
##   SUPABASE_DB_PASSWORD — Database password set in Supabase
##   SUPABASE_DB_URL      — Full PostgreSQL connection string
##   SUPABASE_SERVICE_KEY — Service role key from Supabase
##   SECRET_KEY           — Langfuse secret key (sk-lf-...)
##   PUBLIC_KEY           — Langfuse public key (pk-lf-...)
##   LANGFUSE_URL         — Langfuse host (default: cloud.langfuse.com)
##################################################################

##=========================
## Openrouter Credentials
##=========================
OPENROUTER_API_KEY=""

##====================
## OpenAI Credentials
##====================
OEPNAI_API_KEY=""

##========================
## Supabase Credentials
##========================
SUPABASE_URL=""
SUPABASE_DB_PASSWORD=""
SUPABASE_DB_URL=""
SUPABASE_SERVICE_KEY=""

##=======================
## Langfuse Credentials
##=======================
SECRET_KEY=""
PUBLIC_KEY=""
LANGFUSE_URL=""